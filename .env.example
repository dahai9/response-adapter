# Upstream API credentials (required)
UPSTREAM_API_KEY=sk-your-api-key-here
UPSTREAM_BASE_URL=https://api.openai.com/v1

# Model configuration
# Fixed fallback model (used if no model_map match and no model in request)
# ADAPTER_MODEL=gpt-4o
# Map incoming model names to upstream models (JSON object)
# ADAPTER_MODEL_MAP={"gpt-5.4":"deepseek-v4-flash","gpt-5.5":"deepseek-v4-pro","gpt-5.2":"deepseek-v4-flash","gpt-5.3-codex":"deepseek-v4-flash"}

# Thinking/reasoning mode: "enabled" or "disabled"
# ADAPTER_THINKING=enabled

# Request timeout in seconds (default: 120)
# ADAPTER_TIMEOUT=120

# Server listen address
# ADAPTER_HOST=127.0.0.1
# ADAPTER_PORT=8787

# Custom models list for /v1/models endpoint (JSON array)
# ADAPTER_MODELS=[{"id":"model-a","name":"Model A"}]

# Debug: log converted request body (set to "1" to enable)
# ADAPTER_DEBUG_BODY=1

# Logging level (default: info)
# RUST_LOG=info
